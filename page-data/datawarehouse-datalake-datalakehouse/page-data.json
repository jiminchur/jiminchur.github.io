"https://images.ctfassets.net/jlqgu0ptb6o6/498EeZKXm0kPCrYt8OVUIN/24541fc2ebae46092f15a0d6947c22e9/datalakehoust.png?w=150&h=180&q=50&fm=png 150w,\nhttps://images.ctfassets.net/jlqgu0ptb6o6/498EeZKXm0kPCrYt8OVUIN/24541fc2ebae46092f15a0d6947c22e9/datalakehoust.png?w=300&h=361&q=50&fm=png 300w,\nhttps://images.ctfassets.net/jlqgu0ptb6o6/498EeZKXm0kPCrYt8OVUIN/24541fc2ebae46092f15a0d6947c22e9/datalakehoust.png?w=600&h=722&q=50&fm=png 600w","sizes":"(min-width: 600px) 600px, 100vw"}},"layout":"constrained","backgroundColor":"#f8f8f8","width":774,"height":931},"__typename":"ContentfulAsset"}]}}},"pageContext":{"id":"dbc76b71-252a-5b2e-a5ed-9e2e8f2ac6b9","slug":"datawarehouse-datalake-datalakehouse","__params":{"slug":"datawarehouse-datalake-datalakehouse"}}},"staticQueryHashes":["506648845"],"slicesMap":{}}